# Track large media with Git LFS (run `git lfs install` once per machine).
# Prefer a GitHub attachment / release asset for README demos to avoid repo weight;
# use LFS only when you want the file versioned in the repo itself.
assets/*.mp4 filter=lfs diff=lfs merge=lfs -text
assets/*.mov filter=lfs diff=lfs merge=lfs -text
assets/*.webm filter=lfs diff=lfs merge=lfs -text
assets/*.gif filter=lfs diff=lfs merge=lfs -text
