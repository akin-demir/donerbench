# Agents are listed in backend/donerbench/agents/registry.py.
# Add hosted or local models there, then provide keys/URLs here.

# Default is live model calls. Set to profile only for offline development/tests.
# DONERBENCH_AGENT_MODE=profile

# Logs compact request/response summaries by default.
# Enable full LLM payload/raw response logs while debugging.
DONERBENCH_LOG_LLM_PAYLOADS=false

# Background model call timeout per action.
DONERBENCH_LLM_TIMEOUT_SECONDS=120

# Hosted model agents.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# The OpenAI agent's model string. Override to whatever your account serves.
# OPENAI_MODEL=gpt-5.5

# Local OpenAI-compatible endpoints (Ollama, LM Studio, vLLM, ...).
# These are REQUIRED for the local agents to be selectable — there is no
# hardcoded default. In Docker, host.docker.internal points back to the host.
# LOCAL_LLM_QWEN_BASE_URL=http://host.docker.internal:11434/v1
# LOCAL_LLM_GEMMA_BASE_URL=http://host.docker.internal:11435/v1
